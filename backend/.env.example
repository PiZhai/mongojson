HTTP_ADDR=127.0.0.1:8080
STEWARD_PEER_HTTP_ADDR=
STEWARD_PUBLIC_API_BASE=
STEWARD_ALLOW_REMOTE_MANAGEMENT=false
DATABASE_URL=postgres://postgres:postgres@postgres:5432/mongojson?sslmode=disable
STORAGE_DIR=./data
STEWARD_UI_DIR=
FILE_RETENTION_HOURS=24
STEWARD_SYNC_REQUIRE_AUTH=true
STEWARD_SYNC_ALLOW_INSECURE=false

# R1 durable execution kernel. Keep disabled until the Runtime V2 API is intended to be exposed.
STEWARD_RUNTIME_V2=false
STEWARD_RUNTIME_INTERVAL=1s
STEWARD_RUNTIME_LIMIT=10
# R2.6 worker leases and watchdog. A live worker renews its lease; only expired
# invocations may be recovered automatically.
STEWARD_RUNTIME_LEASE_TTL=10s
STEWARD_RUNTIME_WATCHDOG_INTERVAL=2s
STEWARD_RUNTIME_WATCHDOG_LIMIT=20
# Governed JSON body limit. Larger evidence is reduced to summary + size + hash.
STEWARD_RUNTIME_EVIDENCE_MAX_BYTES=65536

# R2 compiles supported natural-language instructions into immutable R1 plans.
# It implies R1 at runtime, but both flags are explicit here for operational clarity.
STEWARD_RUNTIME_R2=false
# Comma-separated canonical roots. Empty means STORAGE_DIR only.
STEWARD_RUNTIME_ALLOWED_ROOTS=
# Direct executable allowlist for shell.exec. Shell interpreters are not enabled implicitly.
STEWARD_RUNTIME_EXECUTABLES=
# Private/local network targets remain blocked unless their exact hostname is listed here.
STEWARD_RUNTIME_WEB_ALLOWED_HOSTS=
# browser.open_url is not registered unless this is explicitly enabled.
STEWARD_RUNTIME_BROWSER_OPEN_ENABLED=false

# Local rules are always tried first. The optional remote planner only handles unsupported forms.
STEWARD_RUNTIME_PLANNER_PROVIDER=local
# STEWARD_RUNTIME_PLANNER_BASE_URL=https://api.openai.com/v1
# STEWARD_RUNTIME_PLANNER_MODEL=
# STEWARD_RUNTIME_PLANNER_API_KEY=
STEWARD_RUNTIME_PLANNER_ALLOW_NO_API_KEY=false
STEWARD_RUNTIME_PLANNER_TIMEOUT=30s
STEWARD_RUNTIME_PLANNER_MAX_DATA_LEVEL=D1

# R3 isolates A4-A7 actions in a separately installed, higher-privilege
# Privilege Broker. The main service only receives a loopback endpoint, an HMAC
# client key, and the Broker's pinned Ed25519 public key.
STEWARD_RUNTIME_R3=false
STEWARD_BROKER_URL=http://127.0.0.1:18100
# STEWARD_BROKER_CLIENT_KEY=<base64 generated by steward-broker keygen>
# STEWARD_BROKER_PUBLIC_KEY=<base64 generated by steward-broker keygen>

# The following values belong only to the independent steward-broker service,
# never to the main steward service environment:
# STEWARD_BROKER_LISTEN=127.0.0.1:18100
# STEWARD_BROKER_DATA_DIR=./data/privilege-broker
# STEWARD_BROKER_POLICY=./data/privilege-broker/policy.json
# STEWARD_BROKER_STATE=./data/privilege-broker/state.json
# STEWARD_BROKER_AUDIT=./data/privilege-broker/audit.jsonl
# STEWARD_BROKER_CHECKPOINT=./data/privilege-broker/checkpoint.json
# STEWARD_BROKER_CONTROL_KEY=<independent base64 key generated by steward-broker keygen; Broker/admin only, never Steward>
# STEWARD_BROKER_SIGNING_PRIVATE_KEY=<base64 generated by steward-broker keygen>
# STEWARD_BROKER_GRANT_TTL=30s
# STEWARD_BROKER_REQUEST_SKEW=30s

# R3.1 Approval Authority keys are generated by `steward-approval keygen`.
# Only the public key belongs in Broker policy v2. Never place
# STEWARD_APPROVAL_PRIVATE_KEY in this main-service/Broker environment file.

# S4 autonomy advisor is disabled unless explicitly configured.
# STEWARD_LLM_PROVIDER=openai-compatible
# STEWARD_LLM_BASE_URL=https://api.openai.com/v1
# STEWARD_LLM_MODEL=
# STEWARD_LLM_API_KEY=
# STEWARD_LLM_TIMEOUT=20s
# STEWARD_LLM_MAX_DATA_LEVEL=D1
# STEWARD_LLM_FAILURE_THRESHOLD=3
# STEWARD_LLM_FAILURE_COOLDOWN=1m
